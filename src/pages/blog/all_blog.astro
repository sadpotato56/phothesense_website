---
// Import Layout và Components
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/Blog_post_card.astro';
import YellowCard from '../../components/Yellow_Blog_post_card.astro';

// 1. Import hàm getCollection từ Astro


// 2. Lấy toàn bộ bài viết từ thư mục 'blog'
const allPosts = await getCollection('blog');

// 3. Sắp xếp bài viết mới nhất lên đầu (Dựa vào ngày đăng)
const sortedPosts = allPosts.sort((a, b) => {
  // Chuyển đổi chuỗi ngày "DD/MM/YYYY" (như 08/02/2026) thành Date object để so sánh
  const parseDate = (dateStr: string) => {
    if (dateStr.includes('/')) {
      const [day, month, year] = dateStr.split('/');
      return new Date(`${year}-${month}-${day}`);
    }
    return new Date(dateStr);
  };
  
  return parseDate(b.data.date).valueOf() - parseDate(a.data.date).valueOf();
});

// 4. (Tùy chọn) Hàm tính thời gian đọc dựa trên số lượng từ (200 từ/phút)
const calculateReadTime = (text: string) => {
  const words = text.trim().split(/\s+/).length;
  const time = Math.ceil(words / 200);
  return `${time} Min Read`;
};




---

<Layout title="All Stories - PHOTHESENSE" headerType="subpage">
    
    <div class="intro-container">
        <h1>Explore stories from Vietnam</h1>
        <p>Go with a plan. Come back with a story. Discover iconic recommendations, insights and experiences curated by Local Experts.</p>
    </div>

    <div class="archive-container">
        
        <div class="posts-grid">
            
            <div class="grid-item">
                <YellowCard />
            </div>

            {sortedPosts.map((post) => (
                <div class="grid-item">
                    <BlogCard 
                        title={post.data.title}
                        date={post.data.date}
                        readTime={calculateReadTime(post.body)} 
                        location={post.data.category}
                        image={post.data.thumbnail}
                        url={`/blog/${post.slug}`}
                    />
                </div>
            ))}

          

        </div>
    </div>
</Layout>

<style>
    /* --- Styles cho trang chính --- */
    
    /* Intro */
    .intro-container {
        max-width: 1540px;
        margin: 120px auto 60px; /* Căn giữa, cách top 120px */
        padding: 0 20px;
    }

    .intro-container h1 {
        font-family: 'Inter', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 20px;
        color: #1a1a1a;
    }

    .intro-container p {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        color: #555;
        max-width: 800px;
        line-height: 1.6;
    }

    /* Archive Grid */
    .archive-container {
        max-width: 1540px;
        margin: 0 auto;
        padding: 0 20px 100px; /* Padding bottom lớn để thoáng chân trang */
    }

    .posts-grid {
        display: grid;
        /* Desktop: 4 cột đều nhau */
        grid-template-columns: repeat(4, 1fr); 
        
        /* Khoảng cách: Dọc 60px (thoáng), Ngang 24px */
        gap: 60px 24px; 
    }

    /* RESPONSIVE */
    
    /* Tablet lớn: 3 cột */
    @media (max-width: 1200px) {
        .posts-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    /* Tablet nhỏ: 2 cột */
    @media (max-width: 768px) {
        .intro-container h1 { font-size: 2.5rem; }
        .posts-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 40px 16px;
        }
    }

    /* Mobile: 1 cột */
    @media (max-width: 480px) {
        .posts-grid {
            grid-template-columns: 1fr;
        }
        /* Trên mobile, thẻ vàng có thể cần chỉnh lại chiều cao */
        .grid-item:first-child {
            min-height: 300px;
        }
    }
</style>