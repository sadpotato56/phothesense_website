---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    thumbnail: string;
    category: string;
    date: string;
    // Dùng cho chiến lược Topic Cluster
    relatedPosts?: string[]; 
  };
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;
const { title, description, thumbnail, category, date } = frontmatter;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<Layout title={title} headerType="subpage">
  <div id="header-placeholder" data-base-path="../"></div>

  <article class="container py-5 blog-post-container">
    <div class="row">
      
      <div class="col-lg-8 pe-lg-5">
        <header class="post-header mb-5">
          <nav class="breadcrumb mb-2">
            <a href="/blog">Blog</a> / <span class="category">{category}</span>
          </nav>
          <h1 class="post-title display-4 fw-bold">{title}</h1>
          <div class="post-meta text-muted">
            <span class="date"><i class="fa-regular fa-calendar"></i> {date}</span>
          </div>
        </header>

        <div class="post-thumbnail mb-5">
          <img 
            src={thumbnail} 
            alt={title} 
            class="img-fluid rounded-4 shadow-sm" 
            loading="lazy" 
          />
        </div>

        <section class="post-content mb-5">
          <div class="introduction lead mb-4">
            {description}
          </div>
          
          <div class="markdown-body">
            <slot />
          </div>
        </section>

        <hr class="my-5" />

        <section class="related-posts-section mb-5">
          <h3 class="section-title h4 mb-4">Cùng chủ đề: {category}</h3>
          <div class="row g-3">
             <slot name="related-links" />
          </div>
        </section>
      </div>

      <div class="col-lg-4 d-none d-lg-block">
        <aside class="toc-sidebar">
          <div class="toc-container">
            <h4 class="toc-title">Table of Contents</h4>
            <ul class="toc-list">
              {toc.map((heading) => (
                <li class={`toc-item depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>

    </div> <div class="row justify-content-center mt-4">
      <div class="col-lg-10">
        <section class="cta-box p-4 p-md-5 rounded-4 text-center bg-dark text-white">
          <h2 class="mb-3">Ready to Explore Vietnam with Phothesense?</h2>
          <p class="mb-4 text-white-50">
            Join our travel community for exclusive tour packages, hidden gem guides, and 10% off your first booking.
          </p>
          <form action="#" method="POST" class="d-flex flex-column flex-md-row justify-content-center gap-2">
            <input 
              type="email" 
              class="form-control w-auto" 
              placeholder="Enter your email address..." 
              aria-label="Email address"
              required 
            />
            <button type="submit" class="btn btn-primary px-4 text-nowrap">
              Subscribe Now
            </button>
          </form>
        </section>
      </div>
    </div>
  </article>

  <div id="footer-placeholder" data-base-path="../"></div>
  
</Layout>

<style>
/* --- Root & Container Settings --- */
:root {
    --primary-color: #007bff;
    --text-main: #2d3436;
    --text-muted: #636e72;
    --bg-light: #f9f9f9;
    --border-radius: 12px;
}

body {
    padding-top: 80px;
}

.blog-post-container {
    font-family: 'Inter', -apple-system, sans-serif;
    color: var(--text-main);
}

/* --- Post Header & Meta --- */
.post-header .breadcrumb {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
}

.post-header .category {
    color: var(--primary-color);
    font-weight: 600;
}

.post-title {
    line-height: 1.2;
    margin-top: 10px;
    color: #1a1a1a;
}

.post-meta svg {
    margin-right: 5px;
}

/* --- Content Styling (Markdown Body) --- */
.markdown-body {
    font-size: 1.15rem;
    line-height: 1.85;
}

/* Heading chuẩn SEO & Visual Hierarchy */
.markdown-body h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-top: 3rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #eee;
    color: #111;
}

.markdown-body h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    color: #333;
}

.markdown-body p {
    margin-bottom: 1.5rem;
}

.markdown-body strong {
    color: #000;
}

/* Hình ảnh trong bài viết */
.markdown-body img {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    margin: 2.5rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}

/* Blockquotes & Lists */
.markdown-body blockquote {
    border-left: 4px solid var(--primary-color);
    padding: 1rem 2rem;
    background: var(--bg-light);
    font-style: italic;
    margin: 2rem 0;
}

.markdown-body ul, .markdown-body ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
}

.markdown-body li {
    margin-bottom: 0.5rem;
}

/* --- Topic Clusters Box --- */
.related-posts-section {
    background: var(--bg-light);
    padding: 2rem;
    border-radius: var(--border-radius);
}

.related-post-card {
    background: white;
    padding: 1rem;
    border-radius: 8px;
    transition: transform 0.2s ease;
    border: 1px solid #eee;
}

.related-post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

/* --- CTA Box --- */
.cta-box {
    margin-top: 4rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.cta-box h2 {
    font-size: 1.75rem;
}

.cta-box .form-control {
    border-radius: 30px;
    padding: 0.75rem 1.5rem;
}

.cta-box .btn-primary {
    border-radius: 30px;
    font-weight: 600;
    background-color: var(--primary-color);
    border: none;
    transition: all 0.3s ease;
}

/* --- CSS CHUẨN CHO SIDEBAR MỤC LỤC STICKY --- */
.toc-sidebar {
    position: sticky;
    top: 120px;
    align-self: flex-start;
}

.toc-container {
    background-color: #FFFCEE;
    border-radius: var(--border-radius);
    padding: 24px;
    border: 1px solid #eee;
}

.toc-title {
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
    color: #1a1a1a;
    border-bottom: 2px solid var(--primary-color);
    padding-bottom: 8px;
    display: inline-block;
}

.toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.toc-item {
    margin-bottom: 10px;
    line-height: 1.4;
}

.toc-item.depth-3 {
    padding-left: 16px;
    font-size: 0.95rem;
}

.toc-item a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
}

.toc-item a:hover {
    color: var(--primary-color);
    text-decoration: underline;
    text-underline-offset: 3px;
}

/* Responsive Tweaks */
@media (max-width: 768px) {
    .post-title { font-size: 2rem; }
    .markdown-body { font-size: 1.05rem; }
}

/* Styling đặc thù cho Markdown Content */
.markdown-body :global(h2) {
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: #1a1a1a;
    scroll-margin-top: 100px; /* Chống bị menu che khi bấm link mục lục */
}

.markdown-body :global(h3) {
    scroll-margin-top: 100px; /* Chống bị menu che khi bấm link mục lục */
}

.markdown-body :global(p) {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    line-height: 1.8;
}

/* Hình ảnh đứng độc lập trong bài viết */
.markdown-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    margin: 2.5rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}

/* --- STYLE CHO CỤM ẢNH CÓ CHÚ THÍCH (FIGURE & FIGCAPTION) --- */
.markdown-body :global(figure) {
    margin: 2.5rem 0; /* Giữ khoảng cách tổng thể cho cụm ảnh */
    text-align: center; /* Căn giữa toàn bộ */
}

.markdown-body :global(figure img) {
    margin: 0; /* Xóa margin gốc để chú thích dính sát vào mép dưới ảnh */
    margin-bottom: 12px; /* Tạo khoảng cách nhỏ vừa phải giữa ảnh và chữ */
}

.markdown-body :global(figcaption) {
    font-size: 0.95rem; /* Chữ nhỏ hơn nội dung bài một chút */
    font-style: italic; /* In nghiêng nghệ thuật */
    color: var(--text-muted); /* Màu xám tinh tế, không chói mắt */
    line-height: 1.5;
    max-width: 80%; /* Giúp dòng text dài tự rớt dòng đẹp mắt ở giữa */
    margin: 0 auto; /* Đảm bảo khối chữ nằm giữa */
}

/* --- LỆNH TRỊ DỨT ĐIỂM LỖI MENU ĐÈ MỤC LỤC --- */
:global(html) {
    scroll-padding-top: 120px; /* Chừa khoảng thở 120px cho thanh menu */
    scroll-behavior: smooth;   /* Hiệu ứng trượt cuộn siêu mượt */
}
</style>